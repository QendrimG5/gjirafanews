{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/gjirafanews",
    "Audience": "gjirafanews-api",
    "RequireHttpsMetadata": false
  },
  "Cors": {
    "AdminWebOrigin": "http://localhost:3002"
  },
  "Cache": {
    "ArticleListTtlSeconds": 3000,
    "ArticleDetailTtlSeconds": 30000,
    "ArticleListMaxSize": 500
  },
  "S3": {
    "Bucket": "gjirafanews",
    "Region": "us-east-1",
    "ServiceUrl": null,
    "ForcePathStyle": false,
    "PresignedUrlExpiryMinutes": 60,
    "MaxParts": 10000,
    "PublicRead": false
  },
  "Email": {
    "Host": "papercut",
    "Port": 2525,
    "From": "noreply@gjirafanews.local",
    "FromName": "GjirafaNews",
    "SecureSocketOptions": "None",
    "Html": true
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "Topic": "messages.demo",
    "ConsumerGroup": "gjirafanews-api",
    "RecentBufferSize": 100
  }
}
